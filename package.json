{
  "name": "react-video-player-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "dev:vue": "pnpm --filter playground-vue dev",
    "build:pkg": "pnpm --filter @glitchlab/react-video-player build",
