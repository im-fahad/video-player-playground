{
  "name": "@glitchlab/vue-video-player",
  "version": "0.1.0",
  "description": "Vue 3 / Nuxt 3 video player with HLS support, device toggle, and Tailwind CSS styling",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./nuxt": {
      "types": "./dist/nuxt-module.d.ts",
      "import": "./dist/nuxt-module.mjs",
      "require": "./dist/nuxt-module.cjs"
    }
  },
  "sideEffects": ["./dist/style.css"],
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "nuxt3",
    "video",
    "player",
    "hls",
    "hls.js",
    "streaming",
    "m3u8",
    "video-player",
    "vue-player",
    "typescript",
    "tailwindcss",
    "responsive",
    "mobile",
    "desktop",
    "adaptive",
    "overlay",
    "hover-play",
    "device-toggle"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/glitchlab/vue-video-player"
  },
  "peerDependencies": {
    "vue": ">=3",
    "hls.js": ">=1"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@nuxt/kit": "^3.0.0",
    "@types/node": "^20",
    "@vitejs/plugin-vue": "^5",
    "autoprefixer": "^10.4.27",
    "hls.js": "^1.5.0",
    "nuxt": "^3.0.0",
    "postcss": "^8.5.8",
    "@tailwindcss/postcss": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vite": "^5",
    "vite-plugin-dts": "^3",
    "vue": "^3.4.0",
    "vue-tsc": "^2"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  }
}
